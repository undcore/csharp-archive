@page "/Account/Login"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using BlazorWeb.Data

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Login</PageTitle>

<h1>로그인</h1>
<div class="row">
    <div class="col-md-4">
        <section>
            <StatusMessage Message="@sErrorMessage" />
            <EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login">
                <DataAnnotationsValidator />
                <h2>아이디 또는 이메일로 로그인</h2>
                <hr />
                <ValidationSummary class="text-danger" role="alert" />
                <div class="form-floating mb-3">
                    <InputText @bind-Value="Input.LoginId" class="form-control" autocomplete="username" aria-required="true" placeholder="userid or name@example.com" />
                    <label for="login-id" class="form-label">아이디 또는 이메일</label>
                    <ValidationMessage For="() => Input.LoginId" class="text-danger" />
                </div>
                <div class="form-floating mb-3">
                    <InputText type="password" @bind-Value="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label for="password" class="form-label">비밀번호</label>
                    <ValidationMessage For="() => Input.Password" class="text-danger" />
                </div>
                <div class="checkbox mb-3">
                    <label class="form-label">
                        <InputCheckbox @bind-Value="Input.RememberMe" class="darker-border-checkbox form-check-input" />
                        로그인 유지
                    </label>
                </div>
                <div>
                    <button type="submit" class="w-100 btn btn-lg btn-primary">로그인</button>
                </div>
                <div>
                    <p>
                        <a href="Account/ForgotPassword">비밀번호를 잊으셨나요?</a>
                    </p>
                    <p>
                        <a href="@(NavigationManager.GetUriWithQueryParameters("Account/Register", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))">새 계정 만들기</a>
                    </p>
                    <p>
                        <a href="Account/ResendEmailConfirmation">이메일 인증 다시 받기</a>
                    </p>
                </div>
            </EditForm>
        </section>
    </div>
    <div class="col-md-6 col-md-offset-2">
        <section>
            <h3>외부 로그인</h3>
            <hr />
            <ExternalLoginPicker />
        </section>
    </div>
</div>

@code {
    private string? sErrorMessage;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            // Clear the existing external cookie to ensure a clean login process
            await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);
        }
    }

    public async Task LoginUser()
    {
        string sLoginId = Input.LoginId.Trim();
        ApplicationUser? applicationUser = await UserManager.FindByNameAsync(sLoginId);

        if (applicationUser is null)
        {
            applicationUser = await UserManager.FindByEmailAsync(sLoginId);
        }

        if (applicationUser is null)
        {
            sErrorMessage = "Error: Invalid login attempt.";
            return;
        }

        SignInResult signInResult = await SignInManager.CheckPasswordSignInAsync(applicationUser, Input.Password, lockoutOnFailure: false);

        if (signInResult.Succeeded)
        {
            await SignInManager.SignInAsync(applicationUser, Input.RememberMe);
            Logger.LogInformation("User logged in.");
            RedirectManager.RedirectTo(ReturnUrl);
        }
        else if (signInResult.RequiresTwoFactor)
        {
            RedirectManager.RedirectTo(
                "Account/LoginWith2fa",
                new() { ["returnUrl"] = ReturnUrl, ["rememberMe"] = Input.RememberMe });
        }
        else if (signInResult.IsLockedOut)
        {
            Logger.LogWarning("User account locked out.");
            RedirectManager.RedirectTo("Account/Lockout");
        }
        else if (signInResult.IsNotAllowed)
        {
            sErrorMessage = "Error: 이메일 인증 후 로그인할 수 있습니다.";
        }
        else
        {
            sErrorMessage = "Error: Invalid login attempt.";
        }
    }

    private sealed class InputModel
    {
        [Required]
        public string LoginId { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Display(Name = "Remember me?")]
        public bool RememberMe { get; set; }
    }
}
